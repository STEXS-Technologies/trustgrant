{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.org/trustgrant/v0/schema.json",
  "title": "TrustGrant v0 Schema",
  "$comment": "v0 validation schema. This schema is the machine contract baseline for the first TrustGrant v0 implementation. Selector kinds remain issuer-defined in v0 and may represent authority, namespace, project, resource, tag, or other deployment-specific dimensions. For v1 hardening, use short-lived grants, explicit mint operation=create, duplicate-selector rejection, restricted expressions, and deterministic canonical signature profiles.",
  "type": "object",
  "required": [
    "trustgrant_id",
    "version",
    "grant_series_id",
    "revision",
    "supersession_policy",
    "issuer_authority",
    "origin_authority",
    "active_owning_authority",
    "key_id",
    "target_scope",
    "capabilities",
    "resource_scope",
    "issued_at",
    "signature"
  ],
  "properties": {
    "trustgrant_id": {
      "type": "string",
      "pattern": "^tg_[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
      "description": "Canonical TrustGrant document identifier generated by issuer tooling before signing."
    },
    "version": {
      "type": "integer",
      "const": 0
    },
    "grant_series_id": {
      "type": "string",
      "pattern": "^tgs_[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
      "description": "Stable lineage identifier shared by revisions of the same logical delegation, generated by issuer tooling."
    },
    "revision": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonically increasing revision number within one grant_series_id."
    },
    "supersedes": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^tg_[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        }
      ],
      "description": "Optional previous trustgrant_id in the same lineage."
    },
    "supersession_policy": {
      "type": "string",
      "enum": [
        "coexist",
        "supersede_previous"
      ],
      "description": "Whether a new revision coexists with or automatically supersedes older revisions in the same lineage."
    },
    "issuer_authority": {
      "type": "string",
      "minLength": 1
    },
    "origin_authority": {
      "type": "string",
      "minLength": 1,
      "description": "Immutable canonical origin authority for the referenced lineage."
    },
    "active_owning_authority": {
      "type": "string",
      "minLength": 1,
      "description": "Current owning authority for owner-level delegation and settlement."
    },
    "target_scope": {
      "$ref": "#/definitions/scope"
    },
    "capabilities": {
      "type": "object",
      "required": [
        "recognize",
        "mint"
      ],
      "properties": {
        "recognize": {
          "type": "boolean"
        },
        "mint": {
          "type": "boolean",
          "description": "v0 capability flag. v1 hardening SHOULD require explicit operations.allow includes create when mint=true."
        }
      },
      "additionalProperties": false
    },
    "default_audience_scope": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/audienceEntry"
          }
        }
      ]
    },
    "resource_scope": {
      "type": "object",
      "required": [
        "types"
      ],
      "properties": {
        "types": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/resourceType"
          }
        }
      },
      "additionalProperties": false
    },
    "global_constraints": {
      "$ref": "#/definitions/globalConstraints"
    },
    "revocation": {
      "$ref": "#/definitions/revocation"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "signature": {
      "type": "string",
      "minLength": 1
    },
    "issuer_principal": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": [
            "kind",
            "id"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "minLength": 1
            },
            "id": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "key_id": {
      "type": "string",
      "minLength": 1,
      "description": "Identifier of the signing key used for this TrustGrant (root or delegated)."
    },
    "interoperability_profile": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Profile name (e.g. shared_inventory_v1)."
        },
        "version": {
          "type": "integer",
          "description": "Profile version."
        }
      },
      "required": ["name", "version"],
      "additionalProperties": false,
      "description": "Optional interoperability profile declaration. Without a profile, operations.all only authorizes built-in operations (recognize for v0)."
    }
  },
  "additionalProperties": false,
  "definitions": {
    "scope": {
      "type": "object",
      "required": [
        "all",
        "allow",
        "deny"
      ],
      "properties": {
        "all": {
          "type": "boolean"
        },
        "allow": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/definitions/selector"
              }
            }
          ]
        },
        "deny": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/definitions/selector"
              }
            }
          ]
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "all": {
                "const": true
              }
            }
          },
          "then": {
            "properties": {
              "allow": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "all": {
                "const": false
              }
            }
          },
          "then": {
            "properties": {
              "allow": {
                "type": "array"
              }
            }
          }
        }
      ]
    },
    "selector": {
      "type": "object",
      "required": [
        "kind",
        "all",
        "values",
        "expressions"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "all": {
          "type": "boolean"
        },
        "values": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "expressions": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            }
          ],
          "description": "v0 permits expressions. v1 hardening SHOULD restrict to a tiny built-in predicate set or disable expressions entirely."
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "all": {
                "const": true
              }
            }
          },
          "then": {
            "properties": {
              "values": {
                "type": "null"
              },
              "expressions": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "all": {
                "const": false
              }
            }
          },
          "then": {
            "anyOf": [
              {
                "properties": {
                  "values": {
                    "type": "array"
                  }
                }
              },
              {
                "properties": {
                  "expressions": {
                    "type": "array"
                  }
                }
              }
            ]
          }
        }
      ]
    },
    "resourceType": {
      "type": "object",
      "required": [
        "all",
        "allow",
        "deny",
        "capabilities",
        "constraints"
      ],
      "properties": {
        "all": {
          "type": "boolean"
        },
        "allow": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/definitions/selector"
              }
            }
          ]
        },
        "deny": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/definitions/selector"
              }
            }
          ]
        },
        "capabilities": {
          "$ref": "#/definitions/typeCapabilities"
        },
        "constraints": {
          "$ref": "#/definitions/typeConstraints"
        },
        "operations": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/definitions/operationScope"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "typeCapabilities": {
      "type": "object",
      "required": [
        "recognize",
        "mint"
      ],
      "properties": {
        "recognize": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "mint": {
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "typeConstraints": {
      "type": "object",
      "required": [
        "minting"
      ],
      "properties": {
        "minting": {
          "type": "object",
          "properties": {
            "max_total": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "max_per_user": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "audience_scope": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/definitions/audienceEntry"
              }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "operationScope": {
      "type": "object",
      "required": [
        "all",
        "allow",
        "deny"
      ],
      "properties": {
        "all": {
          "type": "boolean"
        },
        "allow": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ]
        },
        "deny": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ]
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "all": {
                "const": true
              }
            }
          },
          "then": {
            "properties": {
              "allow": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "all": {
                "const": false
              }
            }
          },
          "then": {
            "properties": {
              "allow": {
                "type": "array"
              }
            }
          }
        }
      ]
    },
    "audienceEntry": {
      "type": "object",
      "required": [
        "authority_id",
        "scope"
      ],
      "properties": {
        "authority_id": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "$ref": "#/definitions/scope"
        },
        "principal_scope": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/definitions/scope"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "globalConstraints": {
      "type": "object",
      "properties": {
        "time": {
          "type": "object",
          "required": [
            "not_before",
            "not_after"
          ],
          "properties": {
            "not_before": {
              "type": "string",
              "format": "date-time"
            },
            "not_after": {
              "type": "string",
              "format": "date-time"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "revocation": {
      "type": "object",
      "required": [
        "revocable",
        "revocation_endpoint"
      ],
      "properties": {
        "revocable": {
          "type": "boolean"
        },
        "revocation_endpoint": {
          "type": "string",
          "description": "Revocation status endpoint. Empty string when revocable is false. v1 hardening SHOULD combine short-lived grants with cached/bounded-staleness revocation checks."
        },
        "post_revocation_effect": {
          "type": "string",
          "enum": ["block_all", "block_minting_only"],
          "default": "block_all",
          "description": "Defines which operations are affected after revocation. block_all blocks all operations; block_minting_only blocks only future mint operations."
        }
      },
      "additionalProperties": false
    }
  }
}
